# Backend environment variables
SECRET=your-secret-key-here-min-32-chars-change-in-production
FRONTEND_URL=http://localhost:5173
PORT=4000
NODE_ENV=development

# MongoDB Connection (required for v2)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ivory-thread

# Stripe Integration (optional, for payments)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# QR / UPI payment display
UPI_ID=ivorythread@upi
UPI_NAME=Ivory Thread
